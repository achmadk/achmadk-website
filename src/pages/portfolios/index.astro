---
import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'

import BaseHead from '../../components/BaseHead.astro'
import Header from '../../components/Header.astro'
import BigSection from '../../components/02-molecules/texts/BigSection.astro'
import Footer from '../../components/Footer.astro'

import BaseHTML from '@/components/01-atoms/BaseHTML.astro'
import PortfolioCard from '@/components/02-molecules/cards/PortfolioCard'

export const getStaticPaths = (async () => {
  let portfolios: any[] = []
  let params = {}
  try {
    portfolios = await getCollection('portfolios')
    return [{ props: { portfolios }, params }]
  } catch {
    return [{ props: { portfolios }, params }]
  }
}) satisfies GetStaticPaths

const portfolios = await getCollection('portfolios')

const typeLabels: Record<string, string> = {
  WEB_APP: 'Web Apps and Websites',
  MOBILE_APP: 'Mobile Apps',
  LIBRARY: 'TS/JS Libraries and Rust Crates for Open Source Communities'
}

const typeOrder = ['WEB_APP', 'MOBILE_APP', 'LIBRARY'] as const

const groupedPortfolios = typeOrder
  .map((type) => ({
    type,
    label: typeLabels[type],
    items: portfolios
      .filter((p) => p.data.type === type)
      .sort((a, b) => b.data.monthStarted.localeCompare(a.data.monthStarted))
  }))
  .filter((group) => group.items.length > 0)
---

<BaseHTML>
  <head>
    <BaseHead title={`Achmad Kurnianto - Portfolios`} />
  </head>
  <body>
    <Header />
    <main class='container mx-auto mt-20'>
      <BigSection
        title='Portfolios'
        description='Welcome to my space where I share my artworks!'
        viewTransitionName='my-portfolios'
      />
      {
        groupedPortfolios.map((group) => (
          <>
            <section class='flex justify-center my-4'>
              <h3 class='group-title text-primary'>{group.label}</h3>
            </section>
            <section class='flex flex-wrap justify-center' style='gap: 1rem;'>
              {group.items.map((post) => (
                // @ts-expect-error
                <PortfolioCard
                  client:only
                  transition:persist
                  {...{ post, href: `/portfolios/${post.id}/` }}
                />
              ))}
            </section>
          </>
        ))
      }
    </main>
    <Footer />
  </body>
</BaseHTML>

<style lang='scss'>
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .portfolio-group {
    margin-bottom: 2.5rem;
  }

  .group-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
    // color: oklch(0.5 0.15 var(--hue, 240));
  }

  .card {
    img {
      min-height: 12.5rem;
      object-fit: cover;
    }

    // Start hidden until scrolled into view
    opacity: 0;
    transform: translateY(24px);

    // Enhanced shadow with hover lift effect
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.2),
      0 4px 6px -4px rgba(0, 0, 0, 0.15) !important;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease !important;

    &:hover {
      transform: translateY(-8px) !important;
      box-shadow:
        0 25px 50px -12px rgba(0, 0, 0, 0.25),
        0 12px 20px -8px rgba(0, 0, 0, 0.2) !important;
    }

    // Staggered entrance animation on scroll
    &.is-visible {
      animation: fadeSlideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;

      @for $i from 1 through 12 {
        &:nth-child(#{$i}) {
          animation-delay: #{($i - 1) * 80}ms;
        }
      }
    }
  }

  :global(.dark) .card {
    box-shadow:
      0 10px 15px -3px rgba(15, 15, 25, 0.7),
      0 4px 6px -4px rgba(15, 15, 25, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.05) inset,
      0 2px 8px rgba(0, 0, 0, 0.3) !important;

    &:hover {
      box-shadow:
        0 25px 50px -12px rgba(10, 10, 20, 0.8),
        0 12px 20px -8px rgba(10, 10, 20, 0.7),
        0 0 0 1px rgba(255, 255, 255, 0.08) inset,
        0 4px 16px rgba(0, 0, 0, 0.4) !important;
    }
  }
</style>

<script lang='ts'>
  document.addEventListener('astro:page-load', () => {
    const portfolioLinks = document.querySelectorAll('button.btn')
    portfolioLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault()
        e.stopPropagation()
        window.open(
          link.getAttribute('data-url'),
          '_blank',
          'noopener,noreferrer'
        )
      })
    })

    const cards = document.querySelectorAll('.card')
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible')
            observer.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.1 }
    )
    cards.forEach((card) => observer.observe(card))
  })
</script>
