---
import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'

import BaseHead from '../../components/BaseHead.astro'
import EyebrowTag from '../../components/01-atoms/EyebrowTag.astro'
import AnimatedEntrance from '../../components/01-atoms/AnimatedEntrance.astro'
import Footer from '../../components/Footer.astro'
import Header from '../../components/Header.astro'
import BaseHTML from '@/components/01-atoms/BaseHTML.astro'
import PortfolioCard from '@/components/02-molecules/cards/PortfolioCard'
import BigSection from '@/components/02-molecules/texts/BigSection.astro'

export const getStaticPaths = (async () => {
  let portfolios: any[] = []
  let params = {}
  try {
    portfolios = await getCollection('portfolios')
    return [{ props: { portfolios }, params }]
  } catch {
    return [{ props: { portfolios }, params }]
  }
}) satisfies GetStaticPaths

const portfolios = await getCollection('portfolios')

const typeLabels: Record<string, string> = {
  WEB_APP: 'Web Apps and Websites',
  MOBILE_APP: 'Mobile Apps',
  LIBRARY: 'TS/JS Libraries and Rust Crates for Open Source Communities'
}

const typeOrder = ['WEB_APP', 'MOBILE_APP', 'LIBRARY'] as const

const groupedPortfolios = typeOrder
  .map((type) => ({
    type,
    label: typeLabels[type],
    items: portfolios
      .filter((p) => p.data.type === type)
      .sort((a, b) => b.data.monthStarted.localeCompare(a.data.monthStarted))
  }))
  .filter((group) => group.items.length > 0)
---

<BaseHTML>
  <head>
    <BaseHead title={`Achmad Kurnianto - Portfolios`} />
  </head>
  <body>
    <Header />
    <main class='page-main'>
      <AnimatedEntrance class='page-title'>
        <BigSection
          eyebrow='Work'
          title='Portfolios'
          description='Welcome to my space where I share my artworks!'
          viewTransitionName='my-portfolios'
        />
      </AnimatedEntrance>

      {groupedPortfolios.map((group, gi) => (
        <>
          <div class='portfolio-group-header'>
            <div class="group-bezel-outer">
              <div class="group-bezel-inner">
                <h2 class='group-title'>{group.label}</h2>
              </div>
            </div>
          </div>
          <section class='portfolio-grid'>
            {group.items.map((post, pi) => (
              // @ts-expect-error
              <PortfolioCard
                client:load
                {...{ post, href: `/portfolios/${post.id}/` }}
                delay={gi * 100 + pi * 80}
              />
            ))}
          </section>
        </>
      ))}
    </main>
    <Footer />
  </body>
</BaseHTML>

<style lang="scss">
  .page-main {
    padding-top: 8rem;
    min-height: 100dvh;
  }

  .page-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    text-align: center;
    gap: 1rem;
  }

  .page-title-text {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-accent);
    margin: 0;
  }

  .page-title-desc {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 32rem;
  }

  .portfolio-group-header {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 1.5rem 1.5rem;
  }

  .group-bezel-outer {
    display: inline-block;
    padding: 0.1875rem;
    border-radius: var(--radius-lg);
    background: var(--color-border-hair);
    border: 1px solid var(--color-border-subtle);
    box-shadow: var(--shadow-ambient);
    transition: box-shadow 0.4s cubic-bezier(0.32, 0.72, 0, 1);

    &:hover {
      box-shadow: var(--shadow-ambient-lg);
    }
  }

  .group-bezel-inner {
    border-radius: calc(var(--radius-lg) - 0.1875rem);
    background: var(--color-surface-card);
    box-shadow: var(--shadow-inner-highlight);
  }

  .group-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
    text-align: center;
    padding: 0.5rem 1.25rem;
    line-height: 1;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 0 1.5rem 4rem;
    max-width: 80rem;
    margin: 0 auto;
    justify-items: center;

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    @media (min-width: 1024px) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
