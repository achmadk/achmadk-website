---
import BaseHTML from '@/components/01-atoms/BaseHTML.astro'
import BaseHead from '@/components/BaseHead.astro'
import EyebrowTag from '@/components/01-atoms/EyebrowTag.astro'
import AnimatedEntrance from '@/components/01-atoms/AnimatedEntrance.astro'
import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'
import BigSection from '@/components/02-molecules/texts/BigSection.astro'

interface Experience {
  date: string
  title: string
}

const experiences: Experience[] = [
  {
    date: 'January 2026 - Present',
    title: 'Independent Software Engineer / Frontend Consultant'
  },
  {
    date: 'January 2025 - January 2026',
    title: 'Frontend Developer at InnoQB'
  },
  {
    date: 'January 2024 - December 2024',
    title: 'Software Engineer at Pendar'
  },
  {
    date: 'February 2018 - December 2023',
    title: 'Software Engineer at ProcurA'
  },
  {
    date: 'March 2016 - January 2018',
    title: 'Hybrid Mobile Developer at Vhiweb'
  }
]
---

<BaseHTML>
  <head>
    <BaseHead title='Achmad Kurnianto - Experiences' />
  </head>
  <body>
    <Header />
    <main class='page-main'>
      <AnimatedEntrance class='page-title'>
        <BigSection
          eyebrow='Career'
          title='Experiences'
          description='My work experiences over the years.'
          viewTransitionName='my-experiences'
        />
      </AnimatedEntrance>

      <section class='timeline-section'>
        <div class='timeline-track'>
          {
            experiences.map((exp, i) => (
              <AnimatedEntrance delay={String(i * 100)} class='timeline-item'>
                <div class='timeline-card'>
                  <div class='timeline-card-inner'>
                    <time class='timeline-date'>{exp.date}</time>
                    <div class='timeline-title'>{exp.title}</div>
                  </div>
                </div>
                {i < experiences.length - 1 && (
                  <div class='timeline-connector' />
                )}
              </AnimatedEntrance>
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</BaseHTML>

<style lang='scss'>
  .page-main {
    padding-top: 8rem;
    min-height: 100dvh;
  }

  .page-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    text-align: center;
    gap: 1rem;
  }

  .page-title-text {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-accent);
    margin: 0;
  }

  .page-title-desc {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 32rem;
  }

  /* ── Premium Timeline ─────────────────────────────────── */
  .timeline-section {
    padding: 0 1.5rem 6rem;
  }

  .timeline-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 42rem;
    margin: 0 auto;
    gap: 0;
  }

  .timeline-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    position: relative;
  }

  .timeline-card {
    width: 100%;
    border-radius: var(--radius-xl);
    padding: 0.25rem;
    background: var(--color-border-hair);
    border: 1px solid var(--color-border-subtle);
    box-shadow: var(--shadow-ambient);
    transition:
      transform 0.5s cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 0.5s cubic-bezier(0.32, 0.72, 0, 1);

    &:hover {
      transform: translateY(-0.25rem);
      box-shadow: var(--shadow-ambient-lg);
    }
  }

  .timeline-card-inner {
    border-radius: calc(var(--radius-xl) - 0.25rem);
    padding: 1.75rem 2rem;
    background: var(--color-surface-card);
    box-shadow: var(--shadow-inner-highlight), var(--shadow-inner-depth);
  }

  .timeline-date {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 0.5rem;
  }

  .timeline-title {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    line-height: 1.4;
  }

  .timeline-connector {
    width: 2px;
    height: 3rem;
    background: linear-gradient(
      to bottom,
      var(--color-border-subtle),
      transparent
    );
    margin: 0 auto;
  }
</style>
