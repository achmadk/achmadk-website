---
import BaseHTML from '@/components/01-atoms/BaseHTML.astro'
import BaseHead from '@/components/BaseHead.astro'
import EyebrowTag from '@/components/01-atoms/EyebrowTag.astro'
import AnimatedEntrance from '@/components/01-atoms/AnimatedEntrance.astro'
import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'
import BigSection from '@/components/02-molecules/texts/BigSection.astro'
---

<BaseHTML>
  <head>
    <BaseHead title='Achmad Kurnianto - Uses' />
  </head>
  <body>
    <Header />
    <main class='page-main'>
      <AnimatedEntrance class='page-title'>
        <BigSection
          eyebrow='Toolkit'
          title='Uses'
          description='The hardware and software I use throughout my work.'
          viewTransitionName='my-uses'
        />
      </AnimatedEntrance>

      <section class='uses-grid'>
        <AnimatedEntrance class='uses-section' delay='100'>
          <h2 class='uses-section-title'>Hardware</h2>
          <ul class='uses-list'>
            <li class='use-item'>
              <a
                href='https://www.axiooworld.com/mybook-z-series'
                target='_blank'
                rel='noopener noreferrer'
                class='use-link'
              >
                Axioo Z10 Metal Notebook
              </a>
              <p class='use-desc'>
                Affordable dev notebook with latest-gen Intel. Great for
                developers on a budget.
              </p>
              <ul class='use-specs'>
                <li>
                  Intel i5 12th Gen — massive upgrade from my old i3 2nd gen
                </li>
                <li>
                  40GB DDR4 3200MHz — runs Android Studio, VSCode, and 100
                  Chrome tabs
                </li>
                <li>512GB NVMe PCI-E Gen 3 — upgradable to 2TB Gen 4</li>
              </ul>
            </li>
            <li class='use-item'>
              <a
                href='https://www.benq.com/en-us/monitor/home/gw2280.html'
                target='_blank'
                rel='noopener noreferrer'
                class='use-link'
              >
                BenQ GW2280 External Monitor
              </a>
              <p class='use-desc'>
                Affordable external monitor with low blue light feature.
              </p>
            </li>
            <li class='use-item'>
              <a
                href='https://leapfroglobal.com/amg/Armaggeddon-atom-7/armaggeddon-gaming-audio-2.1-for-PC'
                target='_blank'
                rel='noopener noreferrer'
                class='use-link'
              >
                Armaggeddon Atom 7 Headset
              </a>
              <p class='use-desc'>
                Comfortable gaming-grade headset for long coding sessions.
              </p>
            </li>
          </ul>
        </AnimatedEntrance>

        <AnimatedEntrance class='uses-section' delay='300'>
          <h2 class='uses-section-title'>Software</h2>
          <ul class='uses-list'>
            <li class='use-item'>
              <a
                href='https://code.visualstudio.com/'
                target='_blank'
                rel='noopener noreferrer'
                class='use-link'
              >
                Visual Studio Code
              </a>
              <p class='use-desc'>Best lightweight IDE for app development.</p>
            </li>
            <li class='use-item'>
              <a
                href='https://developer.android.com/studio'
                target='_blank'
                rel='noopener noreferrer'
                class='use-link'
              >
                Android Studio
              </a>
              <p class='use-desc'>
                Great for Android and Kotlin multiplatform app development.
              </p>
            </li>
            <li class='use-item'>
              <a
                href='https://www.youtube.com/premium'
                target='_blank'
                rel='noopener noreferrer'
                class='use-link'
              >
                YouTube Premium
              </a>
              <p class='use-desc'>
                No ads, background playback. Essential for learning videos.
              </p>
            </li>
            <li class='use-item'>
              <a
                href='https://notesnook.com/'
                target='_blank'
                rel='noopener noreferrer'
                class='use-link'
              >
                Notesnook
              </a>
              <p class='use-desc'>
                Notion-like with privacy-first and end-to-end encryption.
              </p>
            </li>
          </ul>
        </AnimatedEntrance>
      </section>
    </main>
    <Footer />
  </body>
</BaseHTML>

<style lang='scss'>
  .page-main {
    padding-top: 8rem;
    min-height: 100dvh;
  }

  .page-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    text-align: center;
    gap: 1rem;
  }

  .page-title-text {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-accent);
    margin: 0;
  }

  .page-title-desc {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 32rem;
  }

  /* ── Uses Grid ──────────────────────────────────────────── */
  .uses-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 0 1.5rem 6rem;
    max-width: 56rem;
    margin: 0 auto;

    @media (min-width: 768px) {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  .uses-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .uses-section-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-accent);
    margin: 0;
    margin-bottom: 1rem;
  }

  .uses-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .use-item {
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-xl);
    background: var(--color-border-hair);
    border: 1px solid var(--color-border-subtle);
    transition:
      transform 0.5s cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 0.5s cubic-bezier(0.32, 0.72, 0, 1);

    &:hover {
      transform: translateY(-0.25rem);
      box-shadow: var(--shadow-ambient);
    }
  }

  .use-link {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.3s cubic-bezier(0.32, 0.72, 0, 1);

    &:hover {
      color: var(--color-accent-hover);
    }
  }

  .use-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0.5rem 0 0;
  }

  .use-specs {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0.75rem 0 0;
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    line-height: 1.6;

    li {
      margin-bottom: 0.375rem;
    }
  }
</style>
