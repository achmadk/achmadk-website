---
import type { GetStaticPaths } from 'astro'
import BaseHead from '../../components/BaseHead.astro'
import EyebrowTag from '../../components/01-atoms/EyebrowTag.astro'
import AnimatedEntrance from '../../components/01-atoms/AnimatedEntrance.astro'
import Footer from '../../components/Footer.astro'
import Header from '../../components/Header.astro'
import BigSection from '@/components/02-molecules/texts/BigSection.astro'

import { loadBlogsData } from '@/controllers'
import type { Post } from '@/utilities'
import BaseHTML from '@/components/01-atoms/BaseHTML.astro'
import BlogCard from '@/components/02-molecules/cards/BlogCard'

export const getStaticPaths = (async () => {
  let posts: Post[] = []
  let params = {}
  try {
    const blogsDataResponse = await loadBlogsData()
    posts = blogsDataResponse.posts
    return [{ props: { posts }, params }]
  } catch {
    return [{ props: { posts }, params }]
  }
}) satisfies GetStaticPaths

const { posts } = (await loadBlogsData()) ?? { posts: [] }
---

<BaseHTML>
  <head>
    <BaseHead title={`Achmad Kurnianto - Blogs`} />
  </head>
  <body>
    <Header />
    <main class='page-main'>
      <AnimatedEntrance class='page-title'>
        <BigSection
          eyebrow='Writing'
          title='Blogs'
          description='My place to share knowledge and opinions.'
          viewTransitionName='my-blogs'
        />
      </AnimatedEntrance>
      <!-- <AnimatedEntrance class='page-title'>
        <EyebrowTag>Writing</EyebrowTag>
        <h1 class='page-title-text'>Blogs</h1>
        <p class='page-title-desc'>My place to share knowledge and opinions.</p>
      </AnimatedEntrance> -->

      <section class='blog-grid'>
        {
          posts?.map((post, i) => (
            <BlogCard
              client:load
              href={`/blogs/${post.slug}/`}
              post={post}
              delay={i * 80}
            />
          )) ?? null
        }
      </section>
    </main>
    <Footer />
  </body>
</BaseHTML>

<style lang='scss'>
  .page-main {
    padding-top: 8rem;
    min-height: 100dvh;
  }

  .page-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    text-align: center;
    gap: 1rem;
  }

  .page-title-text {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-accent);
    margin: 0;
  }

  .page-title-desc {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 32rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 0 1.5rem 6rem;
    max-width: 80rem;
    margin: 0 auto;
    justify-items: center;

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    @media (min-width: 1024px) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
