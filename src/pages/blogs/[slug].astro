---
import BaseHTML from "@/components/01-atoms/BaseHTML.astro";
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import EyebrowTag from "@/components/01-atoms/EyebrowTag.astro";
import { loadBlogBySlugData, loadBlogsData } from "@/controllers";

import './_slug.scss';

export async function getStaticPaths() {
  const { posts } = await loadBlogsData()
  return posts.map(({ slug }) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

const response = await loadBlogBySlugData({ slug })

const { post } = response

const fallbackImgURL = 'https://daisyui.com/images/stock/photo-1507358522600-9f71e620c44e.jpg'

---
<BaseHTML>
  <head>
    <BaseHead />
  </head>
  <body>
    <Header />
    {post !== null ? (
      <main class="article-page">
        <div class="article-hero" transition:name={`article-hero-${post.id}`} style={`background-image: url(${post.coverImage?.url ?? fallbackImgURL});`}>
          <div class="article-hero-overlay"></div>
          <div class="article-hero-content">
            <EyebrowTag>Blog</EyebrowTag>
            <h1 transition:name={`article-title-${post.id}`}>{post.title}</h1>
          </div>
        </div>
        <article class="article-body">
          <Fragment set:html={post.content?.html ?? null} />
        </article>
      </main>
    ): null}
  </body>
</BaseHTML>

<style lang="scss">
  .article-page {
    min-height: 100dvh;
  }

  .article-hero {
    position: relative;
    width: 100%;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    margin-top: 5rem;
  }

  .article-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--color-surface) 0%, transparent 60%);
  }

  .article-hero-content {
    position: relative;
    padding: 3rem 1.5rem 2rem;
    max-width: 56rem;
    margin: 0 auto;
    width: 100%;

    h1 {
      font-size: clamp(1.75rem, 4vw, 3rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--color-text-primary);
      margin: 0.75rem 0 0;
    }
  }

  .article-body {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;

    h1, h2, h3, h4, h5, h6 {
      font-weight: 700;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    p {
      line-height: 1.8;
      color: var(--color-text-secondary);
      margin-bottom: 1.25rem;
    }

    ul, ol {
      padding-left: 1.5rem;
      color: var(--color-text-secondary);
      line-height: 1.8;
    }

    a {
      color: var(--color-accent);
      text-decoration: underline;
    }

    code {
      font-size: 0.875rem;
      background: var(--color-surface-elevated);
      padding: 0.125rem 0.375rem;
      border-radius: var(--radius-sm);
    }

    pre {
      background: var(--color-surface-elevated);
      padding: 1.25rem;
      border-radius: var(--radius-md);
      overflow-x: auto;
      margin: 1.5rem 0;
      border: 1px solid var(--color-border-hair);
    }

    img {
      border-radius: var(--radius-lg);
      margin: 1.5rem 0;
    }
  }
</style>
