---
import EyebrowTag from '../../01-atoms/EyebrowTag.astro'

interface Props {
  title?: string
  viewTransitionName?: string
  description?: string
  eyebrow?: string
  size?: 'sm' | 'md' | 'lg'
}

const { title = 'Sample title', viewTransitionName = 'my-blogs', description = '', eyebrow = '', size = 'lg' } = Astro.props
---

<div class="page-title-block" data-size={size}>
  {eyebrow && <EyebrowTag>{eyebrow}</EyebrowTag>}
  <span class="title-decorative" aria-hidden="true" />
  <h1 class="page-title-text" transition:name={viewTransitionName}>{title}</h1>
  {description && <p class="page-title-desc">{description}</p>}
  <span class="divider-accent" aria-hidden="true" />
</div>

<style lang="scss">
  .page-title-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 1.5rem 5rem;
    gap: 1.25rem;
    width: 100%;
    max-width: 56rem;
    margin: 0 auto;
    position: relative;
    overflow: visible;

    &[data-size="sm"] {
      padding: 2.5rem 1.5rem 3rem;
      gap: 1rem;
    }

    &[data-size="md"] {
      padding: 3rem 1.5rem 4rem;
      gap: 1.25rem;
    }

    &[data-size="lg"] {
      padding: 5rem 1.5rem 6rem;
      gap: 1.5rem;
    }
  }

  /* ── Decorative accent bar above title ─────────────────── */
  .title-decorative {
    display: block;
    width: 3rem;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--color-accent), transparent);
    border-radius: 1px;
  }

  /* ── Main Title Text ────────────────────────────────────── */
  .page-title-text {
    font-size: clamp(2.5rem, 7.5vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.4;
    color: var(--color-text-primary);
    margin: 0;
    word-spacing: 0;
    position: relative;
    text-wrap: balance;
    padding: 0.1em 0.15em;
    display: inline-block;
    background: linear-gradient(
      90deg,
      var(--color-text-primary) 0%,
      var(--color-accent) 25%,
      var(--color-text-primary) 50%,
      var(--color-accent) 75%,
      var(--color-text-primary) 100%
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: title-shimmer 8s cubic-bezier(0.32, 0.72, 0, 1) infinite;
  }

  @keyframes title-shimmer {
    0% { background-position: 100% 0%; }
    100% { background-position: 0% 0%; }
  }

  /* ── Description Paragraph ──────────────────────────────── */
  .page-title-desc {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 28rem;
    text-wrap: balance;
    letter-spacing: 0.005em;
    font-weight: 400;
  }

  /* ── Bottom Accent Divider ──────────────────────────────── */
  .divider-accent {
    display: block;
    width: 1.5rem;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    margin-top: 0.5rem;
    opacity: 0.6;
  }
</style>
