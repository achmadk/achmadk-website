---
interface Props {
  label?: string
  className?: string
}

const { label = '', className = '' } = Astro.props
---

<span class:list={['eyebrow-tag', className]}>
  {label}
  <slot />
</span>

<style>
  .eyebrow-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border-radius: var(--radius-full, 9999px);
    padding: 0.25rem 0.75rem;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--color-accent);
    background-color: var(--color-glow-1, rgba(157, 52, 37, 0.08));
    border: 1px solid var(--color-glow-2, rgba(157, 52, 37, 0.04));
  }
</style>
