---
interface Props {
  isOpen?: boolean
  className?: string
  'client:only'?: string
}

const { isOpen = false, className = '' } = Astro.props
---

<button
  type="button"
  class:list={['hamburger-icon', { 'is-open': isOpen }, className]}
  aria-label="Toggle menu"
  aria-expanded={isOpen}
>
  <span class="hamburger-icon-line" />
  <span class="hamburger-icon-line" />
</button>

<style lang="scss">
  .hamburger-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.5rem;
    border: none;
    background: transparent;
    cursor: pointer;
    gap: 0.375rem;
    border-radius: var(--radius-full, 9999px);
    transition: background 0.3s cubic-bezier(0.32, 0.72, 0, 1);

    &:hover {
      background: var(--color-border-hair, rgba(0, 0, 0, 0.06));
    }
  }

  .hamburger-icon-line {
    display: block;
    width: 1.125rem;
    height: 1px;
    background: var(--color-text-primary, rgba(0, 0, 0, 0.88));
    border-radius: 2px;
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1),
                opacity 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .hamburger-icon.is-open {
    .hamburger-icon-line:first-child {
      transform: translateY(0.25rem) rotate(45deg);
    }

    .hamburger-icon-line:last-child {
      transform: translateY(-0.25rem) rotate(-45deg);
    }

    &:hover {
      background: transparent;
    }
  }
</style>
